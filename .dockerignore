# ============================================================================
# .dockerignore - Excluir archivos del build de Docker
# ============================================================================

# Git
.git
.gitignore
.gitattributes

# Python
__pycache__
*.py[cod]
*$py.class
*.so
.Python
*.egg-info
dist
build
*.egg

# Virtual environments
venv/
.venv/
env/
ENV/

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs (se crearán en runtime)
logs/
*.log

# Database backups
backups/
*.sql
*.dump

# Secrets
.env
.env.*
!.env.example
secrets/
*.key
*.pem

# Documentation
*.md
!README.md
docs/

# Docker
docker-compose*.yml
Dockerfile
.dockerignore

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml

# Temp files
tmp/
temp/
cache/
*.tmp

# HuggingFace cache (se descargará en runtime)
.cache/
models/cache/

# Old backups
*_old_*
*.old
*.bak

# Project specific
MIGRATION_TO_MINIMAL_SCHEMA.md
PRODUCTION_DEPLOYMENT.md
DOCKER_QUICKSTART.md
