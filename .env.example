# ============================================================================
# SOC Alerting System - Environment Variables Template
# ============================================================================
# IMPORTANT: Copy this file to .env and fill in your actual values
# NEVER commit .env to git (it's in .gitignore)
# ============================================================================

# ===== DATABASE CONFIGURATION =====
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://soc_user:CHANGE_ME_SECURE_PASSWORD@localhost:5432/soc_alerting

# Connection pool settings
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# ===== NIST NVD API =====
# Get your FREE API key at: https://nvd.nist.gov/developers/request-an-api-key
# WITHOUT API KEY: 5 requests per 30 seconds (very slow!)
# WITH API KEY: 50 requests per 30 seconds (10x faster)
NIST_API_KEY=YOUR_NIST_API_KEY_HERE

# API configuration
NIST_API_BASE_URL=https://services.nvd.nist.gov/rest/json/cves/2.0
NIST_RATE_LIMIT_DELAY=6.0  # Seconds between requests (6s = no API key)

# ===== CISA KEV =====
# CISA Known Exploited Vulnerabilities catalog
CISA_KEV_URL=https://www.cisa.gov/sites/default/files/feeds/known_exploited_vulnerabilities.json
CISA_CACHE_TTL=3600  # Cache for 1 hour (3600 seconds)

# ===== HUGGINGFACE / ML =====
# For NLP enrichment (optional but recommended)
HF_MODEL_NAME=distilbert-base-uncased
HF_CACHE_DIR=/tmp/huggingface_cache
HF_DEVICE=-1  # -1 for CPU, 0 for GPU
HF_MAX_LENGTH=512

# ===== PROCESSING CONFIGURATION =====
# How often to sync CVEs (in minutes)
UPDATE_INTERVAL_MINUTES=60

# Minimum severity to enrich with NLP
# Options: NONE, LOW, MEDIUM, HIGH, CRITICAL
ENRICH_SEVERITY_THRESHOLD=HIGH

# Batch size for processing
BATCH_SIZE=100

# Enable/disable NLP enrichment
ENABLE_ENRICHMENT=true

# ===== RETRY CONFIGURATION =====
# API request retry settings
MAX_RETRIES=3
RETRY_DELAY_SECONDS=5
RETRY_EXPONENTIAL_BACKOFF=true

# ===== LOGGING =====
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
LOG_FILE=logs/soc_alerting.log
LOG_JSON=false  # Enable JSON structured logging

# ===== FEATURES =====
# Enable/disable features
ENABLE_SCHEDULER=true
ENABLE_UPDATE_HISTORY=true

# ===== ENVIRONMENT =====
# Environment: development, staging, production
ENVIRONMENT=production

# SECURITY: Enable debug endpoints ONLY in development!
DEBUG_ENDPOINTS_ENABLED=false

# ===== REDIS (for Celery - REQUIRED for production) =====
# Redis connection for task queue
REDIS_URL=redis://localhost:6379/0

# Celery broker (uses Redis)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ===== DOCKER CONFIGURATION =====
# Variables usadas por docker-compose.yml
POSTGRES_USER=soc_user
POSTGRES_PASSWORD=CHANGE_ME_SECURE_PASSWORD  # ¡CAMBIAR ESTO!
POSTGRES_DB=soc_alerting
POSTGRES_PORT=5432

REDIS_PORT=6379

API_PORT=8000

# ===== SECURITY NOTES =====
# 1. NEVER commit .env to git
# 2. Use strong passwords (minimum 16 characters, mixed case, numbers, symbols)
# 3. For production, use secrets management (Docker Secrets, HashiCorp Vault, AWS Secrets Manager)
# 4. Rotate credentials regularly (every 90 days minimum)
# 5. Use different credentials for dev/staging/production

# ===== COMO USAR =====
# 1. Cambiar POSTGRES_PASSWORD antes de usar docker-compose
# 2. Obtener NIST_API_KEY gratis en: https://nvd.nist.gov/developers/request-an-api-key
# 3. Ejecutar: ./quick-start.sh
# O manualmente:
#    docker-compose up -d postgres redis
#    poetry run alembic upgrade head
#    poetry run uvicorn soc_alerting.api.app:app --reload
