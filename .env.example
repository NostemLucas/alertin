# =============================================================================
# SOC Alert System - Environment Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# For local development (outside Docker):
DATABASE_URL=postgresql://soc_user:secure_password@localhost:5432/soc_alerting

# For Docker development (use service name as host):
# DATABASE_URL=postgresql://soc_user:secure_password@postgres:5432/soc_alerting

# For production (set via .env.production):
DB_PASSWORD=change_this_in_production

# Database pool settings
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# -----------------------------------------------------------------------------
# NIST NVD API
# -----------------------------------------------------------------------------
# Get your API key at: https://nvd.nist.gov/developers/request-an-api-key
NIST_API_KEY=your_api_key_here
NIST_API_BASE_URL=https://services.nvd.nist.gov/rest/json/cves/2.0
NIST_RATE_LIMIT_DELAY=6.0

# -----------------------------------------------------------------------------
# CISA KEV
# -----------------------------------------------------------------------------
CISA_KEV_URL=https://www.cisa.gov/sites/default/files/feeds/known_exploited_vulnerabilities.json
CISA_CACHE_TTL=3600

# -----------------------------------------------------------------------------
# HuggingFace Configuration
# -----------------------------------------------------------------------------
# Model options for CVE analysis:
#   - distilbert-base-uncased (generic, fast but less accurate for security)
#   - jackaduma/SecBERT (security-focused)
#   - PEASEC/CVE-BERT (CVE-specific, BEST for CVE classification)
#   - Fine-tune your own with historical NIST CVE data (best performance)
HF_MODEL_NAME=PEASEC/CVE-BERT
HF_CACHE_DIR=/opt/models
HF_DEVICE=-1
HF_MAX_LENGTH=512

# -----------------------------------------------------------------------------
# Processing Configuration
# -----------------------------------------------------------------------------
UPDATE_INTERVAL_MINUTES=60
ENRICH_SEVERITY_THRESHOLD=HIGH
BATCH_SIZE=100
ENABLE_ENRICHMENT=true
ENABLE_SCHEDULER=true
ENABLE_UPDATE_HISTORY=true

# -----------------------------------------------------------------------------
# Retry Configuration
# -----------------------------------------------------------------------------
MAX_RETRIES=3
RETRY_DELAY_SECONDS=5
RETRY_EXPONENTIAL_BACKOFF=true

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=/var/log/soc-alerting/app.log
LOG_JSON=false

# -----------------------------------------------------------------------------
# Redis (Optional - for caching/Celery)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# Docker-specific (used in docker-compose files)
# -----------------------------------------------------------------------------
# PostgreSQL
POSTGRES_USER=soc_user
POSTGRES_PASSWORD=secure_password
POSTGRES_DB=soc_alerting

# pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@soc-alerting.local
PGADMIN_DEFAULT_PASSWORD=admin
